# Copy this file to .env and fill in real values. .env is gitignored - never commit real keys.

GROQ_API_KEY=
GEMINI_API_KEY=

# Any SQLAlchemy-supported URL works. MySQL for production-style use:
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/hcp_crm
# SQLite for quick local testing without running a MySQL server:
# DATABASE_URL=sqlite:///./dev.db

ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
